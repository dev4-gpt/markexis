# ============================================================
# MARKEXIS AI CMO PLATFORM — Environment Variables Template
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

# --- LLM Providers (priority chain: Groq → Cerebras → Sambanova → NVIDIA → OpenRouter) ---
GROQ_API_KEY=                     # console.groq.com — primary, 14,400 req/day free
CEREBRAS_API_KEY=                 # cloud.cerebras.ai — fallback 1, fastest inference
SAMBANOVA_API_KEY=                # cloud.sambanova.ai — fallback 2, 405B free
NVIDIA_NIM_API_KEY=               # build.nvidia.com — fallback 3
OPENROUTER_API_KEY=               # openrouter.ai — fallback 4, 20+ free models
MERGE_GATEWAY_API_KEY=            # api-gateway.merge.dev — GPT-4o + Claude via promo
GEMINI_API_KEY=                   # aistudio.google.com — multimodal tasks
CLOUDFLARE_ACCOUNT_ID=            # dash.cloudflare.com → AI
CLOUDFLARE_API_TOKEN=             # Cloudflare Workers AI (image gen + LLM fallback)

# --- Data & Scraping ---
FIRECRAWL_API_KEY=                # firecrawl.dev — 1,000 req/mo free
JINA_API_KEY=                     # jina.ai — 1M tokens/mo free, used for RAG embeddings
SUPABASE_URL=https://[project-id].supabase.co
SUPABASE_ANON_KEY=                # Supabase project anon key
GOOGLE_PLACES_API_KEY=            # Places Text Search API
REDDIT_CLIENT_ID=                 # reddit.com/prefs/apps
REDDIT_CLIENT_SECRET=
GITHUB_TOKEN=                     # github.com/settings/tokens (read:user, public_repo)
PEXELS_API_KEY=                   # pexels.com/api — for MoneyPrinterTurbo
PIXABAY_API_KEY=                  # pixabay.com/api — for MoneyPrinterTurbo

# --- Self-hosted services (fill after VPS deploy) ---
SERPBEAR_API_KEY=                 # SerpBear settings page → API key
LISTMONK_API_KEY=                 # Listmonk admin → Users → create API token

# --- Local Mac (scrapers only) ---
N8N_WEBHOOK_URL=http://YOUR_VPS_IP:5678/webhook/lead-ingest
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
# Path to a Chromium/Chrome binary for the LinkedIn Playwright scraper.
# Use the playwright-installed one: find ~/Library/Caches/ms-playwright -name "Google Chrome for Testing" 2>/dev/null
CHROMIUM_PATH=

# --- Gmail SMTP (outreach — sends from Mac, not VPS) ---
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=               # Google Account → Security → App passwords
GMAIL_FROM_NAME=Markexis
